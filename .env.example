# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# PAYMONGO_SECRET_KEY: Required for Paymongo payments.
# Users configure this via the Secrets panel in the AI Studio UI.
PAYMONGO_SECRET_KEY="sk_test_..."

# PAYMONGO_WEBHOOK_SECRET: Secret used to validate PayMongo webhook signatures.
# Set this to your webhook signing secret from PayMongo dashboard.
PAYMONGO_WEBHOOK_SECRET="whsec_..."

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# FIREBASE_PROJECT_ID: Firebase project ID used by Admin SDK in serverless functions.
FIREBASE_PROJECT_ID="cics-upload-490705"

# FIRESTORE_DATABASE_ID: Firestore database ID (optional if default database is used).
FIRESTORE_DATABASE_ID="ai-studio-2f6ca112-61c9-47c0-bdbf-78874120c2d6"

# Option A (recommended): full JSON of service account key (single-line JSON string).
FIREBASE_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"...","client_id":"..."}'

# Option B: separate service account fields.
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"

VITE_RECAPTCHA_SITE_KEY="6LeU7Z4sAAAAAGC3Y7SoFxMGLhynHv5ZTkfySWD8"
RECAPTCHA_SECRET_KEY="6LeU7Z4sAAAAACHvHZ9WUcXxi46liueORX6R3UsR"
